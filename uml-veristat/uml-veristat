#!/bin/bash
# ==============================================================================
# uml-veristat — run veristat against the latest bpf-next kernel in UML
# ==============================================================================
#
# Usage:
#   uml-veristat [--gdb-wait] [veristat-options...] file1.bpf.o [file2.bpf.o ...]
#
# All arguments are passed verbatim to veristat running inside the UML guest.
#
# Environment variables (override auto-detection):
#   UML_KERNEL   — path to the UML kernel binary
#   VERISTAT     — path to the veristat binary
#   UML_MODULES  — space-separated list of .ko files to insmod before veristat
#                  Set to empty string "" to disable auto-loading of modules.
#                  Example: UML_MODULES="/path/to/bpf_testmod.ko ..." uml-veristat ...
#   UML_MEM      — UML guest memory (default: 512M)
#   UML_VERBOSE  — set to 1 to see UML boot messages
#
# Exit codes mirror veristat's exit code.
# ==============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_usage() {
    cat >&2 <<'EOF'
Usage: uml-veristat [--gdb-wait] [veristat-options...] file.bpf.o ...

Wrapper options:
  --gdb-wait   Boot UML, pause before running veristat, print host GDB attach
               instructions, and wait for Enter before continuing.
EOF
}

# ------------------------------------------------------------------------------
# Locate the UML kernel binary
# ------------------------------------------------------------------------------
find_uml_kernel() {
    # 1. Explicit env var
    if [ -n "${UML_KERNEL:-}" ] && [ -x "${UML_KERNEL}" ]; then
        echo "${UML_KERNEL}"; return 0
    fi
    # 2. ~/.local/share/uml-veristat/linux  (installed by build.sh)
    local installed="${HOME}/.local/share/uml-veristat/linux"
    if [ -x "${installed}" ]; then
        echo "${installed}"; return 0
    fi
    # 3. Same directory as this script
    if [ -x "${SCRIPT_DIR}/linux" ]; then
        echo "${SCRIPT_DIR}/linux"; return 0
    fi
    return 1
}

# ------------------------------------------------------------------------------
# Locate the veristat binary
# ------------------------------------------------------------------------------
find_veristat() {
    # 1. Explicit env var
    if [ -n "${VERISTAT:-}" ] && [ -x "${VERISTAT}" ]; then
        echo "${VERISTAT}"; return 0
    fi
    # 2. ~/.local/share/uml-veristat/veristat  (installed by build.sh)
    local installed="${HOME}/.local/share/uml-veristat/veristat"
    if [ -x "${installed}" ]; then
        echo "${installed}"; return 0
    fi
    # 3. Same directory as this script
    if [ -x "${SCRIPT_DIR}/veristat" ]; then
        echo "${SCRIPT_DIR}/veristat"; return 0
    fi
    # 4. System PATH
    if command -v veristat >/dev/null 2>&1; then
        command -v veristat; return 0
    fi
    return 1
}

# ------------------------------------------------------------------------------
# Resolve the list of kernel modules to load inside UML.
#
# Resolution order:
#   1. UML_MODULES env var (if set, even to empty — disables auto-detection)
#   2. ~/.local/share/uml-veristat/*.ko  (installed by build.sh)
#   3. Same directory as this script
#   4. Nothing (proceed without loading any module)
# ------------------------------------------------------------------------------
find_uml_modules() {
    # If UML_MODULES is explicitly set (including to ""), honour it as-is.
    if [ -v UML_MODULES ]; then
        echo "${UML_MODULES}"
        return 0
    fi
    # Auto-detect module-backed selftest prerequisites from well-known locations.
    # Keep the module order aligned with the in-tree selftest loader.
    local modules=(
        "bpf_testmod.ko"
        "bpf_test_modorder_x.ko"
        "bpf_test_modorder_y.ko"
    )
    local found=()
    local module f
    for module in "${modules[@]}"; do
        for f in \
            "${HOME}/.local/share/uml-veristat/${module}" \
            "${SCRIPT_DIR}/${module}"
        do
            if [ -f "${f}" ]; then
                found+=("${f}")
                break
            fi
        done
    done
    echo "${found[*]:-}"
}

GDB_WAIT=0
VERISTAT_ARGS=()
for arg in "$@"; do
    case "${arg}" in
        --gdb-wait) GDB_WAIT=1 ;;
        *) VERISTAT_ARGS+=("${arg}") ;;
    esac
done

# ------------------------------------------------------------------------------
# Validate inputs
# ------------------------------------------------------------------------------
if [ "${#VERISTAT_ARGS[@]}" -eq 0 ]; then
    print_usage
    echo "       uml-veristat --help" >&2
    exit 1
fi

UML_BIN=$(find_uml_kernel) || {
    echo "uml-veristat: UML kernel not found." >&2
    echo "  Run: ${SCRIPT_DIR}/build.sh" >&2
    echo "  Or set: export UML_KERNEL=/path/to/linux" >&2
    exit 1
}

VERISTAT_BIN=$(find_veristat) || {
    echo "uml-veristat: veristat binary not found." >&2
    echo "  Run: ${SCRIPT_DIR}/build.sh" >&2
    echo "  Or set: export VERISTAT=/path/to/veristat" >&2
    exit 1
}

MODULE_LIST=$(find_uml_modules)

# ------------------------------------------------------------------------------
# Resolve all .bpf.o paths to absolute (UML sees host fs via hostfs)
# Build the argument list with absolute paths substituted
# ------------------------------------------------------------------------------
ARGS=()
for arg in "${VERISTAT_ARGS[@]}"; do
    if [ -f "${arg}" ]; then
        ARGS+=("$(realpath "${arg}")")
    else
        ARGS+=("${arg}")
    fi
done

# ------------------------------------------------------------------------------
# Create a temporary working directory on the host.
#
# UML is booted with hostfs=/ (the entire host filesystem mounted read-write
# as the UML root).  The init script and result file therefore live directly
# on the host filesystem and are visible inside UML at their normal absolute
# paths — no separate /host mount point is needed.
# ------------------------------------------------------------------------------
TMPDIR_UML=$(mktemp -d /tmp/uml-veristat-XXXXXX)
INIT_SCRIPT="${TMPDIR_UML}/init"
RESULT_FILE="${TMPDIR_UML}/result"
OUTPUT_FILE="${TMPDIR_UML}/output"
READY_FILE="${TMPDIR_UML}/gdb-ready"
GO_FILE="${TMPDIR_UML}/gdb-go"
UML_PID=""

cleanup() {
    if [ -n "${UML_PID}" ] && kill -0 "${UML_PID}" 2>/dev/null; then
        kill "${UML_PID}" 2>/dev/null || true
        wait "${UML_PID}" 2>/dev/null || true
    fi
    rm -rf "${TMPDIR_UML}"
}
trap cleanup EXIT

# Build the veristat command line as a single quoted string
VERISTAT_CMD="${VERISTAT_BIN}"
for a in "${ARGS[@]}"; do
    VERISTAT_CMD="${VERISTAT_CMD} $(printf '%q' "${a}")"
done

# Build the insmod section for the init script.
# Each module path is already an absolute host path, visible inside UML via hostfs.
# insmod also comes from the host filesystem, so resolve it on the host side:
# minimal container images often ship without kmod, which would otherwise make
# module loading a silent no-op and skew results for module-backed programs.
# The || true ensures a failed insmod does not abort the init script — veristat
# will still run and produce partial results, which is preferable to a hard crash.
INSMOD_CMDS=""
if [ -n "${MODULE_LIST}" ]; then
    INSMOD_BIN="$(command -v insmod || true)"
    if [ -z "${INSMOD_BIN}" ]; then
        for candidate in /usr/sbin/insmod /sbin/insmod /usr/bin/insmod; do
            if [ -x "${candidate}" ]; then INSMOD_BIN="${candidate}"; break; fi
        done
    fi
    if [ -z "${INSMOD_BIN}" ]; then
        echo "uml-veristat: insmod not found on the host (install kmod); modules will NOT be loaded:" >&2
        echo "  ${MODULE_LIST}" >&2
    else
        for mod in ${MODULE_LIST}; do
            INSMOD_CMDS="${INSMOD_CMDS}${INSMOD_BIN} ${mod} 2>/dev/null || true
"
        done
    fi
fi

# The init script runs inside the UML guest.  Because hostfs=/ is the root,
# all host paths are directly accessible at the same absolute paths.
# Veristat stdout+stderr are redirected to OUTPUT_FILE so they are completely
# separated from kernel console messages (including 'sysrq: Power Off').
# The wrapper cats OUTPUT_FILE after UML exits, preserving correct exit code
# handling and clean terminal output.
cat > "${INIT_SCRIPT}" << INIT_EOF
#!/bin/sh
# Mount essential virtual filesystems
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true

# Load kernel modules before running veristat
${INSMOD_CMDS}
# Wait for host GDB attach if requested
if [ "${GDB_WAIT}" = "1" ]; then
    : > ${READY_FILE}
    while [ ! -f ${GO_FILE} ]; do
        sleep 1
    done
fi

# Run veristat; redirect all output to a host-visible file
${VERISTAT_CMD} > ${OUTPUT_FILE} 2>&1
echo \$? > ${RESULT_FILE}
sync

# Halt the UML guest
halt -f 2>/dev/null || poweroff -f 2>/dev/null || echo o > /proc/sysrq-trigger
INIT_EOF

chmod +x "${INIT_SCRIPT}"

# ------------------------------------------------------------------------------
# Boot UML and capture output
# ------------------------------------------------------------------------------
MEM="${UML_MEM:-512M}"
VERBOSE="${UML_VERBOSE:-0}"
GDB_MACROS="${SCRIPT_DIR}/../gdb_demo/verifier.gdb"
UML_EXIT=0

# Base args shared by both modes
UML_ARGS=(
    "mem=${MEM}"
    "rootfstype=hostfs"
    "hostfs=/"
    "rw"                 # mount root read-write so init can write the result file
    "init=${INIT_SCRIPT}"
)

if [ "${GDB_WAIT}" = "1" ]; then
    UML_CONSOLE_ARGS=(quiet loglevel=0 con=null con0=null)
    if [ "${VERBOSE}" = "1" ]; then
        UML_CONSOLE_ARGS=(con=fd:2,fd:2 con0=fd:2,fd:2)
    fi

    if [ "${VERBOSE}" = "1" ]; then
        "${UML_BIN}" "${UML_ARGS[@]}" "${UML_CONSOLE_ARGS[@]}" &
    else
        "${UML_BIN}" "${UML_ARGS[@]}" "${UML_CONSOLE_ARGS[@]}" 2>/dev/null &
    fi
    UML_PID=$!

    for _ in $(seq 1 60); do
        if [ -f "${READY_FILE}" ]; then
            break
        fi
        if ! kill -0 "${UML_PID}" 2>/dev/null; then
            break
        fi
        sleep 1
    done

    if [ ! -f "${READY_FILE}" ]; then
        wait "${UML_PID}" || true
        [ -f "${OUTPUT_FILE}" ] && cat "${OUTPUT_FILE}" >&2
        echo "uml-veristat: UML guest did not reach GDB wait state." >&2
        exit 1
    fi

    echo "uml-veristat: UML guest paused before running veristat." >&2
    echo "  UML PID: ${UML_PID}" >&2
    echo "  Attach with:" >&2
    echo "    gdb ${UML_BIN}" >&2
    echo "    (gdb) attach ${UML_PID}" >&2
    if [ -f "${GDB_MACROS}" ]; then
        echo "    (gdb) source ${GDB_MACROS}" >&2
    fi
    echo "    (gdb) continue" >&2
    echo "  Resume the guest after GDB is ready with:" >&2
    echo "    touch ${GO_FILE}" >&2

    while [ ! -f "${GO_FILE}" ]; do
        if ! kill -0 "${UML_PID}" 2>/dev/null; then
            break
        fi
        sleep 1
    done

    wait "${UML_PID}" 2>/dev/null || UML_EXIT=$?
    UML_PID=""
elif [ "${VERBOSE}" = "1" ]; then
    # Verbose: show full kernel boot log on stderr; veristat output still goes to
    # OUTPUT_FILE (captured in init script) and is replayed cleanly after UML exits.
    "${UML_BIN}" "${UML_ARGS[@]}" \
        con=fd:2,fd:2 con0=fd:2,fd:2 &
    UML_PID=$!
    wait "${UML_PID}" 2>/dev/null || UML_EXIT=$?
    UML_PID=""
else
    # Silent: suppress all kernel console output; veristat output goes to OUTPUT_FILE.
    (
        "${UML_BIN}" "${UML_ARGS[@]}" \
            quiet loglevel=0 \
            con=null con0=null \
            2>/dev/null
    ) 2>/dev/null &
    UML_PID=$!
    wait "${UML_PID}" 2>/dev/null || UML_EXIT=$?
    UML_PID=""
fi

# ------------------------------------------------------------------------------
# Print veristat output and return its exit code
# ------------------------------------------------------------------------------
if [ -f "${RESULT_FILE}" ]; then
    # Replay veristat output (stdout+stderr) captured inside the guest
    [ -f "${OUTPUT_FILE}" ] && cat "${OUTPUT_FILE}"
    exit "$(cat "${RESULT_FILE}")"
else
    # UML crashed or init didn't write result; show whatever output was captured
    [ -f "${OUTPUT_FILE}" ] && cat "${OUTPUT_FILE}" >&2
    echo "uml-veristat: UML guest did not complete normally (UML exit ${UML_EXIT})." >&2
    exit 1
fi
