From 42c10e9e1aed4982835b6d8b931cc621e99dd435 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 13:26:16 -0700
Subject: [PATCH] um/x86: support far BPF calls in UML JIT

The native x86 BPF JIT normally emits direct 32-bit relative calls. Under
UML, host kernel symbols and generated JIT images can be far enough apart
that kfunc/helper targets do not fit in that encoding, causing otherwise
valid programs to fail JIT lowering.

For UML only, resolve call targets through bpf_jit_get_func_addr() and emit
indirect calls through the auxiliary register for non-BPF-to-BPF calls. Keep
BPF-to-BPF calls using the normal direct-call placeholder flow so subprogram
relocation still works as expected.

---
 arch/x86/net/bpf_jit_comp.c | 77 +++++++++++++++++++++++++++++++++++--
 1 file changed, 73 insertions(+), 4 deletions(-)

diff --git a/arch/x86/net/bpf_jit_comp.c b/arch/x86/net/bpf_jit_comp.c
index 7651c39143a6..5ad6dbc01d5d 100644
--- a/arch/x86/net/bpf_jit_comp.c
+++ b/arch/x86/net/bpf_jit_comp.c
@@ -1079,6 +1079,43 @@ static void emit_mov_imm64(u8 **pprog, u32 dst_reg,
 	*pprog = prog;
 }
 
+#ifdef CONFIG_UML
+static void emit_indirect_call(u8 **pprog, void *func)
+{
+	unsigned long addr = (unsigned long)func;
+	u8 *prog = *pprog;
+	int reg = reg2hex[AUX_REG];
+
+	EMIT2(add_1mod(0x48, AUX_REG), add_1reg(0xB8, AUX_REG));
+	EMIT((u32)addr, 4);
+	EMIT(addr >> 32, 4);
+	if (is_ereg(AUX_REG))
+		EMIT1(0x41);
+	EMIT2(0xFF, 0xD0 + reg);
+
+	*pprog = prog;
+}
+
+static int emit_call_or_indirect(u8 **pprog, void *func, void *ip)
+{
+	emit_indirect_call(pprog, func);
+	return 0;
+}
+
+static int emit_direct_call_or_placeholder(u8 **pprog, void *func, void *ip)
+{
+	u8 *prog = *pprog;
+
+	if (!func) {
+		EMIT1_off32(0xE8, 0);
+		*pprog = prog;
+		return 0;
+	}
+
+	return emit_call(pprog, func, ip);
+}
+#endif
+
 static void emit_mov_reg(u8 **pprog, bool is64, u32 dst_reg, u32 src_reg)
 {
 	u8 *prog = *pprog;
@@ -1762,7 +1799,8 @@ static int emit_spectre_bhb_barrier(u8 **pprog, u8 *ip,
 }
 
 static int do_jit(struct bpf_verifier_env *env, struct bpf_prog *bpf_prog, int *addrs, u8 *image,
-		  u8 *rw_image, int oldproglen, struct jit_context *ctx, bool jmp_padding)
+		  u8 *rw_image, int oldproglen, struct jit_context *ctx, bool jmp_padding,
+		  bool extra_pass)
 {
 	bool tail_call_reachable = bpf_prog->aux->tail_call_reachable;
 	struct bpf_insn *insn = bpf_prog->insnsi;
@@ -2659,19 +2697,43 @@ st:			insn_off = insn->off;
 
 			/* call */
 		case BPF_JMP | BPF_CALL: {
-			func = (u8 *) __bpf_call_base + imm32;
+#ifdef CONFIG_UML
+			bool func_addr_fixed;
+			u64 func_addr;
+
+			err = bpf_jit_get_func_addr(bpf_prog, insn, extra_pass,
+						    &func_addr, &func_addr_fixed);
+			if (err < 0)
+				return err;
+			func = (u8 *)func_addr;
+#else
+			func = (u8 *)__bpf_call_base + imm32;
+#endif
 			if (src_reg == BPF_PSEUDO_CALL && tail_call_reachable) {
 				LOAD_TAIL_CALL_CNT_PTR(stack_depth);
 				ip += 7;
 			}
+#ifdef CONFIG_UML
+			if (!func && func_addr_fixed)
+				return -EINVAL;
+#else
 			if (!imm32)
 				return -EINVAL;
+#endif
 			if (priv_frame_ptr) {
 				push_r9(&prog);
 				ip += 2;
 			}
 			ip += x86_call_depth_emit_accounting(&prog, func, ip);
-			if (emit_call(&prog, func, ip))
+#ifdef CONFIG_UML
+			if (src_reg == BPF_PSEUDO_CALL)
+				err = emit_direct_call_or_placeholder(&prog, func, ip);
+			else
+				err = emit_call_or_indirect(&prog, func, ip);
+#else
+			err = emit_call(&prog, func, ip);
+#endif
+			if (err)
 				return -EINVAL;
 			if (priv_frame_ptr)
 				pop_r9(&prog);
@@ -4010,7 +4072,7 @@ struct bpf_prog *bpf_int_jit_compile(struct bpf_verifier_env *env, struct bpf_pr
 		if (!padding && pass >= PADDING_PASSES)
 			padding = true;
 		proglen = do_jit(env, prog, addrs, image, rw_image, oldproglen,
-				 &ctx, padding);
+				 &ctx, padding, extra_pass);
 		if (proglen <= 0) {
 out_image:
 			image = NULL;
@@ -4127,6 +4189,13 @@ bool bpf_jit_supports_kfunc_call(void)
 	return true;
 }
 
+#ifdef CONFIG_UML
+bool bpf_jit_supports_far_kfunc_call(void)
+{
+	return true;
+}
+#endif
+
 bool bpf_jit_supports_stack_args(void)
 {
 	return true;
-- 
