From 4c0bdfe231a790c5d9882ff3ddfd9542a30235a6 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 16:03:36 -0700
Subject: [PATCH] um/x86: validate BPF probe memory against UML ranges

The x86 BPF JIT emits an address check for BPF_PROBE_MEM loads before
the faultable load. Native x86 treats kernel addresses as above
TASK_SIZE_MAX and below VSYSCALL_ADDR.

UML kernel memory is mapped into the host process address space below
TASK_SIZE. Vmalloc allocations such as bpf_ringbuf therefore fail the
native check, and the JIT zeroes the destination register without
issuing the load.

This breaks direct BTF pointer loads, for example map_ptr's
rb->producer_pos check, while helpers reading the same ringbuf state
return the expected value.

For UML, check the effective address against UML's kernel ranges instead:
physical memory [uml_physmem, high_physmem) and vmalloc [start_vm,
end_vm). Keep the existing exception-table fixup for faults.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/x86/net/bpf_jit_comp.c | 78 ++++++++++++++++++++++++++++++++++++++
 1 file changed, 78 insertions(+)

diff --git a/arch/x86/net/bpf_jit_comp.c b/arch/x86/net/bpf_jit_comp.c
index 2ec24d084204..dcfbcb0a13e0 100644
--- a/arch/x86/net/bpf_jit_comp.c
+++ b/arch/x86/net/bpf_jit_comp.c
@@ -24,5 +24,8 @@
 #include <asm/vsyscall.h>
 #include <asm/cfi.h>
+#ifdef CONFIG_UML
+#include <as-layout.h>
+#endif
 
 #ifdef CONFIG_UML
 static const unsigned char x86_nop1[] = { BYTES_NOP1 };
@@ -1282,6 +1283,76 @@ static void emit_ldx(u8 **pprog, u32 size, u32 dst_reg, u32 src_reg, int off)
 	*pprog = prog;
 }
 
+#ifdef CONFIG_UML
+static void emit_uml_load_ulong(u8 **pprog, const unsigned long *ptr)
+{
+	unsigned long addr = (unsigned long)ptr;
+	u8 *prog = *pprog;
+
+	emit_mov_imm64(&prog, BPF_REG_AX, addr >> 32, (u32)addr);
+	emit_ldx(&prog, BPF_DW, BPF_REG_AX, BPF_REG_AX, 0);
+
+	*pprog = prog;
+}
+
+static void emit_uml_probe_mem_check(u8 **pprog, u32 dst_reg, u32 src_reg,
+				     int off, u8 **start_of_ldx)
+{
+	u8 *prog = *pprog;
+	u8 *jmp_to_vmalloc;
+	u8 *jmp_to_phys_load;
+	u8 *jmp_to_zero;
+	u8 *jmp_to_vmalloc_load;
+	u8 *zero_label;
+	u8 *vmalloc_check;
+
+	EMIT_mov(AUX_REG, src_reg);
+	if (off) {
+		maybe_emit_1mod(&prog, AUX_REG, true);
+		EMIT2_off32(0x81, add_1reg(0xC0, AUX_REG), off);
+	}
+
+	emit_uml_load_ulong(&prog, &uml_physmem);
+	maybe_emit_mod(&prog, AUX_REG, BPF_REG_AX, true);
+	EMIT2(0x39, add_2reg(0xC0, AUX_REG, BPF_REG_AX));
+	EMIT2(X86_JB, 0);
+	jmp_to_vmalloc = prog;
+
+	emit_uml_load_ulong(&prog, &high_physmem);
+	maybe_emit_mod(&prog, AUX_REG, BPF_REG_AX, true);
+	EMIT2(0x39, add_2reg(0xC0, AUX_REG, BPF_REG_AX));
+	EMIT2(X86_JB, 0);
+	jmp_to_phys_load = prog;
+
+	vmalloc_check = prog;
+	jmp_to_vmalloc[-1] = vmalloc_check - jmp_to_vmalloc;
+
+	emit_uml_load_ulong(&prog, &start_vm);
+	maybe_emit_mod(&prog, AUX_REG, BPF_REG_AX, true);
+	EMIT2(0x39, add_2reg(0xC0, AUX_REG, BPF_REG_AX));
+	EMIT2(X86_JB, 0);
+	jmp_to_zero = prog;
+
+	emit_uml_load_ulong(&prog, &end_vm);
+	maybe_emit_mod(&prog, AUX_REG, BPF_REG_AX, true);
+	EMIT2(0x39, add_2reg(0xC0, AUX_REG, BPF_REG_AX));
+	EMIT2(X86_JB, 0);
+	jmp_to_vmalloc_load = prog;
+
+	zero_label = prog;
+	jmp_to_zero[-1] = zero_label - jmp_to_zero;
+
+	emit_mov_imm32(&prog, false, dst_reg, 0);
+	EMIT2(0xEB, 0);
+
+	*start_of_ldx = prog;
+	jmp_to_phys_load[-1] = *start_of_ldx - jmp_to_phys_load;
+	jmp_to_vmalloc_load[-1] = *start_of_ldx - jmp_to_vmalloc_load;
+
+	*pprog = prog;
+}
+#endif
+
 /* LDSX: dst_reg = *(s8*)(src_reg + off) */
 static void emit_ldsx(u8 **pprog, u32 size, u32 dst_reg, u32 src_reg, int off)
 {
@@ -2530,6 +2601,10 @@ st:			insn_off = insn->off;
 
 			if (BPF_MODE(insn->code) == BPF_PROBE_MEM ||
 			    BPF_MODE(insn->code) == BPF_PROBE_MEMSX) {
+#ifdef CONFIG_UML
+				emit_uml_probe_mem_check(&prog, dst_reg, src_reg,
+							 insn_off, &start_of_ldx);
+#else
 				/* Conservatively check that src_reg + insn->off is a kernel address:
 				 *   src_reg + insn->off > TASK_SIZE_MAX + PAGE_SIZE
 				 *   and
@@ -2576,6 +2651,7 @@ st:			insn_off = insn->off;
 				/* populate jmp_offset for JAE above to jump to start_of_ldx */
 				start_of_ldx = prog;
 				end_of_jmp[-1] = start_of_ldx - end_of_jmp;
+#endif
 			}
 			if (BPF_MODE(insn->code) == BPF_PROBE_MEMSX ||
 			    BPF_MODE(insn->code) == BPF_MEMSX)
-- 
2.53.0-Meta
