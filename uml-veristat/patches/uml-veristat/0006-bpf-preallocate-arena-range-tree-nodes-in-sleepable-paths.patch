From 6f4f3adc4ea6d2c5b757cee6c7b7da953229f122 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 8 May 2026 22:09:54 -0700
Subject: [PATCH] bpf: preallocate arena range-tree nodes in sleepable paths

Arena maps track free pages in a range_tree. Runtime range-tree updates
use kmalloc_nolock() because they can run under arena->spinlock, but two
sleepable arena paths can also need a new range_node.

arena_map_alloc() seeds the empty tree with the full free range, and
arena_vm_fault() can split a free range when userspace faults an arena
page through mmap(). Those callers are allowed to sleep, but they still
depend on the non-sleepable range-tree allocation path. If
kmalloc_nolock() cannot allocate a node, map creation fails with
-ENOMEM, or a userspace mmap fault can fail while copying arena globals.

Add range_node allocation ownership so nodes allocated from sleepable
paths are freed with kfree(), seed the initial full range with
GFP_KERNEL_ACCOUNT, and let arena_vm_fault() preallocate one split node
before retaking arena->spinlock. range_tree_clear() and range_tree_set()
keep their existing kmalloc_nolock() behavior for normal runtime callers.

This fixes arena map creation and arena objects whose global data is
copied through the user VMA, while preserving the non-sleepable
allocation behavior for regular arena mutations.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 kernel/bpf/arena.c      | 38 ++++++++++++++---
 kernel/bpf/range_tree.c | 92 +++++++++++++++++++++++++++++++++++------
 kernel/bpf/range_tree.h |  7 ++++
 3 files changed, 120 insertions(+), 17 deletions(-)

diff --git a/kernel/bpf/arena.c b/kernel/bpf/arena.c
index af49c1544..e225b2b57 100644
--- a/kernel/bpf/arena.c
+++ b/kernel/bpf/arena.c
@@ -313,7 +313,7 @@ static struct bpf_map *arena_map_alloc(union bpf_attr *attr)
 		goto err_free_arena;
 
 	range_tree_init(&arena->rt);
-	err = range_tree_set(&arena->rt, 0, attr->max_entries);
+	err = range_tree_init_full(&arena->rt, attr->max_entries);
 	if (err)
 		goto err_free_scratch;
 	mutex_init(&arena->lock);
@@ -475,6 +475,7 @@ static vm_fault_t arena_vm_fault(struct vm_fault *vmf)
 	struct bpf_map *map = vmf->vma->vm_file->private_data;
 	struct bpf_arena *arena = container_of(map, struct bpf_arena, map);
 	struct mem_cgroup *new_memcg, *old_memcg;
+	struct range_node *split_node = NULL;
 	struct page *page;
 	long kbase, kaddr;
 	unsigned long flags;
@@ -496,13 +497,27 @@ static vm_fault_t arena_vm_fault(struct vm_fault *vmf)
 		goto out;
 	}
 
-	bpf_map_memcg_enter(&arena->map, &old_memcg, &new_memcg);
-
 	if (arena->map.map_flags & BPF_F_SEGV_ON_FAULT)
 		/* User space requested to segfault when page is not allocated by bpf prog */
-		goto out_sigsegv_memcg;
+		goto out_unlock_no_memcg;
+
+	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
+
+	bpf_map_memcg_enter(&arena->map, &old_memcg, &new_memcg);
+	split_node = range_tree_node_alloc();
+	if (!split_node)
+		goto out_sigsegv_no_lock;
+
+	if (raw_res_spin_lock_irqsave(&arena->spinlock, flags))
+		goto out_retry_no_lock;
+
+	page = vmalloc_to_page((void *)kaddr);
+	if (page) {
+		bpf_map_memcg_exit(old_memcg, new_memcg);
+		goto out;
+	}
 
-	ret = range_tree_clear(&arena->rt, vmf->pgoff, 1);
+	ret = range_tree_clear_with_node(&arena->rt, vmf->pgoff, 1, &split_node);
 	if (ret)
 		goto out_sigsegv_memcg;
 
@@ -524,15 +539,28 @@ static vm_fault_t arena_vm_fault(struct vm_fault *vmf)
 	flush_vmap_cache(kaddr, PAGE_SIZE);
 	bpf_map_memcg_exit(old_memcg, new_memcg);
 out:
+	range_tree_node_free(split_node);
 	page_ref_add(page, 1);
 	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
 	vmf->page = page;
 	return 0;
 out_sigsegv_memcg:
+	range_tree_node_free(split_node);
 	bpf_map_memcg_exit(old_memcg, new_memcg);
 out_sigsegv:
 	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
 	return VM_FAULT_SIGSEGV;
+out_sigsegv_no_lock:
+	range_tree_node_free(split_node);
+	bpf_map_memcg_exit(old_memcg, new_memcg);
+	return VM_FAULT_SIGSEGV;
+out_retry_no_lock:
+	range_tree_node_free(split_node);
+	bpf_map_memcg_exit(old_memcg, new_memcg);
+	return VM_FAULT_RETRY;
+out_unlock_no_memcg:
+	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
+	return VM_FAULT_SIGSEGV;
 }
 
 static const struct vm_operations_struct arena_vm_ops = {
diff --git a/kernel/bpf/range_tree.c b/kernel/bpf/range_tree.c
index 2f28886f3..b699b4ae6 100644
--- a/kernel/bpf/range_tree.c
+++ b/kernel/bpf/range_tree.c
@@ -19,12 +19,14 @@
  * The split/merge logic is based/borrowed from XFS's xbitmap32 added
  * in commit 6772fcc8890a ("xfs: convert xbitmap to interval tree").
  *
- * The implementation relies on external lock to protect rbtree-s.
- * The alloc/free of range_node-s is done via kmalloc_nolock().
+ * The implementation relies on external lock to protect rbtree-s. Runtime
+ * split/merge updates allocate range_node-s via kmalloc_nolock(). Arena
+ * bootstrap uses range_tree_init_full(), which seeds an empty tree with one
+ * sleepable kmalloc()-backed range_node.
  *
  * bpf arena is using range_tree to represent unallocated slots.
  * At init time:
- *   range_tree_set(rt, 0, max);
+ *   range_tree_init_full(rt, max);
  * Then:
  *   start = range_tree_find(rt, len);
  *   if (start >= 0)
@@ -39,6 +41,7 @@ struct range_node {
 	u32 rn_start;
 	u32 rn_last; /* inclusive */
 	u32 __rn_subtree_last;
+	bool sleepable_alloc;
 };
 
 static struct range_node *rb_to_range_node(struct rb_node *rb)
@@ -51,6 +54,39 @@ static u32 rn_size(struct range_node *rn)
 	return rn->rn_last - rn->rn_start + 1;
 }
 
+static struct range_node *range_node_alloc(gfp_t gfp_flags, bool sleepable_alloc)
+{
+	struct range_node *rn;
+
+	if (sleepable_alloc)
+		rn = kmalloc(sizeof(*rn), gfp_flags);
+	else
+		rn = kmalloc_nolock(sizeof(*rn), gfp_flags, NUMA_NO_NODE);
+	if (!rn)
+		return NULL;
+	rn->sleepable_alloc = sleepable_alloc;
+	return rn;
+}
+
+static void range_node_free(struct range_node *rn)
+{
+	if (rn->sleepable_alloc)
+		kfree(rn);
+	else
+		kfree_nolock(rn);
+}
+
+struct range_node *range_tree_node_alloc(void)
+{
+	return range_node_alloc(GFP_KERNEL_ACCOUNT, true);
+}
+
+void range_tree_node_free(struct range_node *rn)
+{
+	if (rn)
+		range_node_free(rn);
+}
+
 /* Find range that fits best to requested size */
 static inline struct range_node *__find_range(struct range_tree *rt, u32 len)
 {
@@ -133,7 +169,8 @@ range_it_iter_first(struct range_tree *rt, u32 start, u32 last)
 }
 
 /* Clear the range in this range tree */
-int range_tree_clear(struct range_tree *rt, u32 start, u32 len)
+static int __range_tree_clear(struct range_tree *rt, u32 start, u32 len,
+			      struct range_node **prealloc)
 {
 	u32 last = start + len - 1;
 	struct range_node *new_rn;
@@ -149,10 +186,14 @@ int range_tree_clear(struct range_tree *rt, u32 start, u32 len)
 			range_it_insert(rn, rt);
 
 			/* Add a range */
-			new_rn = kmalloc_nolock(sizeof(struct range_node), __GFP_ACCOUNT,
-						NUMA_NO_NODE);
-			if (!new_rn)
-				return -ENOMEM;
+			if (prealloc && *prealloc) {
+				new_rn = *prealloc;
+				*prealloc = NULL;
+			} else {
+				new_rn = range_node_alloc(__GFP_ACCOUNT, false);
+				if (!new_rn)
+					return -ENOMEM;
+			}
 			new_rn->rn_start = last + 1;
 			new_rn->rn_last = old_last;
 			range_it_insert(new_rn, rt);
@@ -170,12 +211,23 @@ int range_tree_clear(struct range_tree *rt, u32 start, u32 len)
 		} else {
 			/* in the middle of the clearing range */
 			range_it_remove(rn, rt);
-			kfree_nolock(rn);
+			range_node_free(rn);
 		}
 	}
 	return 0;
 }
 
+int range_tree_clear(struct range_tree *rt, u32 start, u32 len)
+{
+	return __range_tree_clear(rt, start, len, NULL);
+}
+
+int range_tree_clear_with_node(struct range_tree *rt, u32 start, u32 len,
+			       struct range_node **prealloc)
+{
+	return __range_tree_clear(rt, start, len, prealloc);
+}
+
 /* Is the whole range set ? */
 int is_range_tree_set(struct range_tree *rt, u32 start, u32 len)
 {
@@ -223,7 +275,7 @@ int range_tree_set(struct range_tree *rt, u32 start, u32 len)
 		range_it_remove(right, rt);
 		left->rn_last = right->rn_last;
 		range_it_insert(left, rt);
-		kfree_nolock(right);
+		range_node_free(right);
 	} else if (left) {
 		/* Combine with the left range */
 		range_it_remove(left, rt);
@@ -235,7 +287,7 @@ int range_tree_set(struct range_tree *rt, u32 start, u32 len)
 		right->rn_start = start;
 		range_it_insert(right, rt);
 	} else {
-		left = kmalloc_nolock(sizeof(struct range_node), __GFP_ACCOUNT, NUMA_NO_NODE);
+		left = range_node_alloc(__GFP_ACCOUNT, false);
 		if (!left)
 			return -ENOMEM;
 		left->rn_start = start;
@@ -251,10 +303,26 @@ void range_tree_destroy(struct range_tree *rt)
 
 	while ((rn = range_it_iter_first(rt, 0, -1U))) {
 		range_it_remove(rn, rt);
-		kfree_nolock(rn);
+		range_node_free(rn);
 	}
 }
 
+int range_tree_init_full(struct range_tree *rt, u32 len)
+{
+	struct range_node *rn;
+
+	if (range_it_iter_first(rt, 0, -1U))
+		return -EBUSY;
+
+	rn = range_node_alloc(GFP_KERNEL_ACCOUNT, true);
+	if (!rn)
+		return -ENOMEM;
+	rn->rn_start = 0;
+	rn->rn_last = len - 1;
+	range_it_insert(rn, rt);
+	return 0;
+}
+
 void range_tree_init(struct range_tree *rt)
 {
 	rt->it_root = RB_ROOT_CACHED;
diff --git a/kernel/bpf/range_tree.h b/kernel/bpf/range_tree.h
index ff0b9110e..3e5542e62 100644
--- a/kernel/bpf/range_tree.h
+++ b/kernel/bpf/range_tree.h
@@ -10,10 +10,17 @@ struct range_tree {
 	struct rb_root_cached range_size_root;
 };
 
+struct range_node;
+
 void range_tree_init(struct range_tree *rt);
 void range_tree_destroy(struct range_tree *rt);
+int range_tree_init_full(struct range_tree *rt, u32 len);
+struct range_node *range_tree_node_alloc(void);
+void range_tree_node_free(struct range_node *rn);
 
 int range_tree_clear(struct range_tree *rt, u32 start, u32 len);
+int range_tree_clear_with_node(struct range_tree *rt, u32 start, u32 len,
+			       struct range_node **prealloc);
 int range_tree_set(struct range_tree *rt, u32 start, u32 len);
 int is_range_tree_set(struct range_tree *rt, u32 start, u32 len);
 s64 range_tree_find(struct range_tree *rt, u32 len);
-- 
2.53.0-Meta

