From 20040a9bfb460865514b2e00127a86982dec5609 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 13:26:22 -0700
Subject: [PATCH] bpf: use sleepable allocation for arena page arrays

bpf_arena_alloc_pages() can be called from sleepable syscall-test paths.
Those paths still allocate the temporary struct page pointer array with
kmalloc_nolock(), which can fail even for small batches and makes arena page
allocation return NULL before any actual page allocation is attempted.

Use regular kmalloc_array()/kfree() when the caller is sleepable and keep the
existing kmalloc_nolock()/kfree_nolock() path for non-sleepable callers.

---
 kernel/bpf/arena.c | 24 ++++++++++++++++++++----
 1 file changed, 20 insertions(+), 4 deletions(-)

diff --git a/kernel/bpf/arena.c b/kernel/bpf/arena.c
index e225b2b57b96..64535ed129a8 100644
--- a/kernel/bpf/arena.c
+++ b/kernel/bpf/arena.c
@@ -680,6 +680,22 @@ static u64 clear_lo32(u64 val)
 	return val & ~(u64)~0U;
 }
 
+static struct page **arena_alloc_page_array(long page_cnt, bool sleepable)
+{
+	if (sleepable)
+		return kmalloc_array(page_cnt, sizeof(struct page *), GFP_KERNEL_ACCOUNT);
+	return kmalloc_nolock(page_cnt * sizeof(struct page *), __GFP_ACCOUNT,
+			      NUMA_NO_NODE);
+}
+
+static void arena_free_page_array(struct page **pages, bool sleepable)
+{
+	if (sleepable)
+		kfree(pages);
+	else
+		kfree_nolock(pages);
+}
+
 /*
  * Allocate pages and vmap them into kernel vmalloc area.
  * Later the pages will be mmaped into user space vma.
@@ -717,9 +733,9 @@ static long arena_alloc_pages(struct bpf_arena *arena, long uaddr, long page_cnt
 	}
 
 	bpf_map_memcg_enter(&arena->map, &old_memcg, &new_memcg);
-	/* Cap allocation size to KMALLOC_MAX_CACHE_SIZE so kmalloc_nolock() can succeed. */
+	/* Keep batches small enough for non-sleepable kmalloc_nolock(). */
 	alloc_pages = min(page_cnt, KMALLOC_MAX_CACHE_SIZE / sizeof(struct page *));
-	pages = kmalloc_nolock(alloc_pages * sizeof(struct page *), __GFP_ACCOUNT, NUMA_NO_NODE);
+	pages = arena_alloc_page_array(alloc_pages, sleepable);
 	if (!pages) {
 		bpf_map_memcg_exit(old_memcg, new_memcg);
 		return 0;
@@ -781,7 +797,7 @@ static long arena_alloc_pages(struct bpf_arena *arena, long uaddr, long page_cnt
 	}
 	flush_vmap_cache(kern_vm_start + uaddr32, mapped << PAGE_SHIFT);
 	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
-	kfree_nolock(pages);
+	arena_free_page_array(pages, sleepable);
 	bpf_map_memcg_exit(old_memcg, new_memcg);
 	return clear_lo32(arena->user_vm_start) + uaddr32;
 out:
@@ -795,7 +811,7 @@ static long arena_alloc_pages(struct bpf_arena *arena, long uaddr, long page_cnt
 out_unlock_free_pages:
 	raw_res_spin_unlock_irqrestore(&arena->spinlock, flags);
 out_free_pages:
-	kfree_nolock(pages);
+	arena_free_page_array(pages, sleepable);
 	bpf_map_memcg_exit(old_memcg, new_memcg);
 	return 0;
 }
-- 
