diff --git a/kernel/bpf/Kconfig b/kernel/bpf/Kconfig
index eb3de3573..e155f17b3 100644
--- a/kernel/bpf/Kconfig
+++ b/kernel/bpf/Kconfig
@@ -101,4 +101,33 @@ config BPF_LSM
 
 	  If you are unsure how to answer this question, answer N.
 
+config BPF_VERIFICATION_STUBS
+	bool
+	depends on UML
+	depends on BPF_SYSCALL
+	depends on BPF_JIT
+	depends on !PERF_EVENTS
+	depends on !BPF_EVENTS
+	default y
+	help
+	  Provides minimal verifier_ops/prog_ops for BPF program types
+	  that normally require CONFIG_BPF_EVENTS, so the BPF verifier can
+	  accept these types for static analysis on UML kernels without perf
+	  events. Also provides BPF_MAP_TYPE_STACK_TRACE support via
+	  callchain buffer stubs.
+
+	  This is only intended for UML verification-only environments.
+	  Programs are accepted for load-time analysis, but are never
+	  attached or executed.
+
+config BPF_LSM_VERIFICATION_STUBS
+	bool
+	depends on BPF_VERIFICATION_STUBS
+	depends on SECURITY
+	default y
+	help
+	  Provides BPF_PROG_TYPE_LSM, BPF_MAP_TYPE_INODE_STORAGE, BPF LSM
+	  attach targets, and selected LSM kfunc BTF entries for UML
+	  verification-only kernels.
+
 endmenu # "BPF subsystem"
