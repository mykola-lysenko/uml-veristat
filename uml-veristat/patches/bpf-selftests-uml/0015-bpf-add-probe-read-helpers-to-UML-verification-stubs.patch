From 16ea14be04819a2eb2904f3ad24325619bfbf20a Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 15:08:29 -0700
Subject: [PATCH] bpf: add probe read helpers to UML verification stubs

UML verification kernels build without CONFIG_BPF_EVENTS, so they do
not link kernel/trace/bpf_trace.o. That leaves the weak
bpf_probe_read_kernel* helper prototypes from kernel/bpf/helpers.c
without function pointers.

BPF_PROG_TYPE_SYSCALL delegates helper selection to
tracing_prog_func_proto() for these helpers. Generated light-skeleton
loader programs use bpf_probe_read_kernel() while reading their loader
context, so they are rejected before they can load the real selftest
program.

Provide the kernel probe-read helper implementations from the UML
verification-stub object. This keeps the helper surface available in
the no-BPF_EVENTS UML configuration and lets BPF syscall loader
programs execute far enough to create and load their target objects.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 kernel/bpf/bpf_verification_stubs.c | 43 +++++++++++++++++++++++++++++
 1 file changed, 43 insertions(+)

diff --git a/kernel/bpf/bpf_verification_stubs.c b/kernel/bpf/bpf_verification_stubs.c
index c84619e348d2..79c8623d9cbe 100644
--- a/kernel/bpf/bpf_verification_stubs.c
+++ b/kernel/bpf/bpf_verification_stubs.c
@@ -23,9 +23,52 @@
 #include <linux/filter.h>
 #include <linux/perf_event.h>
 #include <linux/pid.h>
+#include <linux/uaccess.h>
 
 /* --- Tracing program type stubs --- */
 
+BPF_CALL_3(bpf_probe_read_kernel, void *, dst, u32, size,
+	   const void *, unsafe_ptr)
+{
+	return bpf_probe_read_kernel_common(dst, size, unsafe_ptr);
+}
+
+const struct bpf_func_proto bpf_probe_read_kernel_proto = {
+	.func		= bpf_probe_read_kernel,
+	.gpl_only	= true,
+	.ret_type	= RET_INTEGER,
+	.arg1_type	= ARG_PTR_TO_UNINIT_MEM,
+	.arg2_type	= ARG_CONST_SIZE_OR_ZERO,
+	.arg3_type	= ARG_ANYTHING,
+};
+
+static __always_inline int
+bpf_probe_read_kernel_str_common_stub(void *dst, u32 size,
+				      const void *unsafe_ptr)
+{
+	int ret;
+
+	ret = strncpy_from_kernel_nofault(dst, unsafe_ptr, size);
+	if (unlikely(ret < 0))
+		memset(dst, 0, size);
+	return ret;
+}
+
+BPF_CALL_3(bpf_probe_read_kernel_str, void *, dst, u32, size,
+	   const void *, unsafe_ptr)
+{
+	return bpf_probe_read_kernel_str_common_stub(dst, size, unsafe_ptr);
+}
+
+const struct bpf_func_proto bpf_probe_read_kernel_str_proto = {
+	.func		= bpf_probe_read_kernel_str,
+	.gpl_only	= true,
+	.ret_type	= RET_INTEGER,
+	.arg1_type	= ARG_PTR_TO_UNINIT_MEM,
+	.arg2_type	= ARG_CONST_SIZE_OR_ZERO,
+	.arg3_type	= ARG_ANYTHING,
+};
+
 BPF_CALL_5(bpf_trace_printk, char *, fmt, u32, fmt_size, u64, arg1,
 	   u64, arg2, u64, arg3)
 {
