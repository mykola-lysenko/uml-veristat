From b8e4f377ac7a722a8fba288f878627f46b042074 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 13:26:34 -0700
Subject: [PATCH] selftests/bpf: fix arena allocator ASM fallback globals

The BPF_ARENA_FORCE_ASM fallback cannot rely on LLVM address_space(1)
lowering. The allocator metadata must live in .addr_space.1 and explicit
addr_space_cast instructions are needed before dereferencing those globals;
otherwise the verifier sees relocated addresses as scalars, or the JIT adds
the arena base to a normal data-map pointer.

Put the allocator metadata, and arena_htab's large arena array, behind
__arena_global. For the ASM fallback, use explicit casts for the allocator
metadata pointers and keep the freshly reset offset in a scalar so the
verifier can prove the refill path makes progress.

---
 tools/testing/selftests/bpf/bpf_arena_alloc.h | 23 ++++++++++++++++---
 .../testing/selftests/bpf/progs/arena_htab.c  |  2 +-
 2 files changed, 21 insertions(+), 4 deletions(-)

diff --git a/tools/testing/selftests/bpf/bpf_arena_alloc.h b/tools/testing/selftests/bpf/bpf_arena_alloc.h
index cda147fd9d25..9408bf7b1cbd 100644
--- a/tools/testing/selftests/bpf/bpf_arena_alloc.h
+++ b/tools/testing/selftests/bpf/bpf_arena_alloc.h
@@ -13,18 +13,29 @@
 #ifdef __BPF__
 #define NR_CPUS (sizeof(struct cpumask) * 8)
 
-static void __arena * __arena page_frag_cur_page[NR_CPUS];
-static int __arena page_frag_cur_offset[NR_CPUS];
+static void __arena * __arena_global page_frag_cur_page[NR_CPUS];
+static int __arena_global page_frag_cur_offset[NR_CPUS];
 
 /* Simple page_frag allocator */
 static inline void __arena* bpf_alloc(unsigned int size)
 {
 	__u64 __arena *obj_cnt;
 	__u32 cpu = bpf_get_smp_processor_id();
+#ifdef BPF_ARENA_FORCE_ASM
+	void __arena **cur_page = &page_frag_cur_page[cpu];
+	int *cur_offset = &page_frag_cur_offset[cpu];
+	void __arena *page;
+#else
 	void __arena *page = page_frag_cur_page[cpu];
 	int __arena *cur_offset = &page_frag_cur_offset[cpu];
+#endif
 	int offset;
 
+#ifdef BPF_ARENA_FORCE_ASM
+	cast_kern(cur_page);
+	cast_kern(cur_offset);
+	page = *cur_page;
+#endif
 	size = round_up(size, 8);
 	if (size >= PAGE_SIZE - 8)
 		return NULL;
@@ -34,16 +45,22 @@ static inline void __arena* bpf_alloc(unsigned int size)
 		if (!page)
 			return NULL;
 		cast_kern(page);
+#ifdef BPF_ARENA_FORCE_ASM
+		*cur_page = page;
+#else
 		page_frag_cur_page[cpu] = page;
+#endif
 		*cur_offset = PAGE_SIZE - 8;
 		obj_cnt = page + PAGE_SIZE - 8;
 		*obj_cnt = 0;
+		offset = PAGE_SIZE - 8;
 	} else {
 		cast_kern(page);
 		obj_cnt = page + PAGE_SIZE - 8;
+		offset = *cur_offset;
 	}
 
-	offset = *cur_offset - size;
+	offset -= size;
 	if (offset < 0)
 		goto refill;
 
diff --git a/tools/testing/selftests/bpf/progs/arena_htab.c b/tools/testing/selftests/bpf/progs/arena_htab.c
index 81eaa94afeb0..9c92dffe5b52 100644
--- a/tools/testing/selftests/bpf/progs/arena_htab.c
+++ b/tools/testing/selftests/bpf/progs/arena_htab.c
@@ -19,7 +19,7 @@ void __arena *htab_for_user;
 bool skip = false;
 
 int zero = 0;
-char __arena arr1[100000];
+char __arena_global arr1[100000];
 char arr2[1000];
 
 SEC("syscall")
