From 59ecd433ed69f9130fc78f82d36dae3609255c50 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 24 Apr 2026 11:03:38 -0700
Subject: [PATCH] selftests/bpf: veristat: cap auto log size to avoid OOM

veristat probes whether the kernel accepts large verifier log buffers and
uses that result to choose the default verbose log size. On UML this can
select a buffer close to one GiB, which is larger than the default guest
memory and can make verbose runs crash before printing verifier output.

Cap the automatic large-log default at 64 MiB. Users can still request a
larger buffer explicitly with --log-size.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>

---
 tools/testing/selftests/bpf/veristat.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/tools/testing/selftests/bpf/veristat.c b/tools/testing/selftests/bpf/veristat.c
index 010ad9c0d..108373349 100644
--- a/tools/testing/selftests/bpf/veristat.c
+++ b/tools/testing/selftests/bpf/veristat.c
@@ -1342,7 +1342,8 @@ static void fixup_obj(struct bpf_object *obj, struct bpf_program *prog, const ch
 static int max_verifier_log_size(void)
 {
 	const int SMALL_LOG_SIZE = UINT_MAX >> 8;
-	const int BIG_LOG_SIZE = UINT_MAX >> 2;
+	/* Keep automatic verbose logging practical on constrained systems. */
+	const int BIG_LOG_SIZE = 64 * 1024 * 1024;
 	struct bpf_insn insns[] = {
 		{ .code = BPF_ALU | BPF_MOV | BPF_X, .dst_reg = BPF_REG_0, },
 		{ .code  = BPF_JMP | BPF_EXIT, },
@@ -1365,6 +1366,7 @@ static int max_verifier_log_size(void)
 	else /* ret == -EINVAL, big log size is not supported by the verifier */
 		log_size = SMALL_LOG_SIZE;
 
+	/* Larger logs can still be requested explicitly with --log-size. */
 	return log_size;
 }
 
