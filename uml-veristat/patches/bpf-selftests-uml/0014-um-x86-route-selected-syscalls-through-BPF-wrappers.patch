From 64063802cb3d19d25a212d906ad7b783ed9b6b7b Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 14:30:43 -0700
Subject: [PATCH] um/x86: route selected syscalls through BPF wrappers

UML now provides synthetic __x64_sys_* wrappers for BPF attach target
compatibility, but the normal UML syscall dispatch path still calls
the underlying sys_* table entries directly. Runtime fentry/fexit
programs attached to the synthetic wrappers can attach successfully
but never execute.

Route the small set of syscall numbers covered by the synthetic
wrappers through those wrappers before falling back to the existing
syscall table path. The wrappers delegate to the same sys_*
implementations, so syscall behavior stays unchanged while BPF
trampoline attachments observe the expected wrapper entry.

This keeps the compatibility code scoped to the BPF-selftest wrapper
set instead of changing UML's whole syscall table ABI.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/um/kernel/skas/syscall.c | 38 +++++++++++++++++++++++++++++------
 1 file changed, 32 insertions(+), 6 deletions(-)

diff --git a/arch/um/kernel/skas/syscall.c b/arch/um/kernel/skas/syscall.c
index ba7494f9bfe4..2e41000f17d5 100644
--- a/arch/um/kernel/skas/syscall.c
+++ b/arch/um/kernel/skas/syscall.c
@@ -14,6 +14,31 @@
 #include <asm/unistd.h>
 #include <asm/delay.h>
 
+static bool maybe_call_x64_syscall_wrapper(struct pt_regs *regs, int syscall,
+					   unsigned long *ret)
+{
+#ifdef CONFIG_X86_64
+	switch (syscall) {
+	case __NR_getpgid:
+		*ret = __x64_sys_getpgid(regs);
+		return true;
+	case __NR_nanosleep:
+		*ret = __x64_sys_nanosleep(regs);
+		return true;
+	case __NR_prctl:
+		*ret = __x64_sys_prctl(regs);
+		return true;
+	case __NR_prlimit64:
+		*ret = __x64_sys_prlimit64(regs);
+		return true;
+	case __NR_setdomainname:
+		*ret = __x64_sys_setdomainname(regs);
+		return true;
+	}
+#endif
+	return false;
+}
+
 void handle_syscall(struct uml_pt_regs *r)
 {
 	struct pt_regs *regs = container_of(r, struct pt_regs, regs);
@@ -45,12 +70,13 @@ void handle_syscall(struct uml_pt_regs *r)
 	if (syscall >= 0 && syscall < __NR_syscalls) {
 		unsigned long ret;
 
-		ret = (*sys_call_table[syscall])(UPT_SYSCALL_ARG1(&regs->regs),
-						 UPT_SYSCALL_ARG2(&regs->regs),
-						 UPT_SYSCALL_ARG3(&regs->regs),
-						 UPT_SYSCALL_ARG4(&regs->regs),
-						 UPT_SYSCALL_ARG5(&regs->regs),
-						 UPT_SYSCALL_ARG6(&regs->regs));
+		if (!maybe_call_x64_syscall_wrapper(regs, syscall, &ret))
+			ret = (*sys_call_table[syscall])(UPT_SYSCALL_ARG1(&regs->regs),
+							 UPT_SYSCALL_ARG2(&regs->regs),
+							 UPT_SYSCALL_ARG3(&regs->regs),
+							 UPT_SYSCALL_ARG4(&regs->regs),
+							 UPT_SYSCALL_ARG5(&regs->regs),
+							 UPT_SYSCALL_ARG6(&regs->regs));
 
 		PT_REGS_SET_SYSCALL_RETURN(regs, ret);
 
