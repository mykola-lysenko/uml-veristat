From 36fa6fcb1d06972ac0ea0cbedd3e8aeb31c41686 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 13:26:11 -0700
Subject: [PATCH] bpf: add test_run support to UML verification stubs

The UML verification stubs expose tracing and raw tracepoint program types
for load-time analysis when CONFIG_BPF_EVENTS is unavailable. Runtime
selftests can also exercise these program types through BPF_PROG_TEST_RUN,
but empty prog_ops leave test_run unsupported.

Wire the existing tracing and raw tracepoint test_run handlers into the stub
prog_ops so selected runtime selftests can execute under a verification-only
UML kernel. Keep the raw tracepoint hook behind CONFIG_NET to match the
definition site.

---
 kernel/bpf/bpf_verification_stubs.c | 21 +++++++++++++++++----
 1 file changed, 17 insertions(+), 4 deletions(-)

diff --git a/kernel/bpf/bpf_verification_stubs.c b/kernel/bpf/bpf_verification_stubs.c
index 4dabb53d3ea4..c84619e348d2 100644
--- a/kernel/bpf/bpf_verification_stubs.c
+++ b/kernel/bpf/bpf_verification_stubs.c
@@ -80,18 +80,31 @@ static bool stub_tracing_is_valid_access(int off, int size,
 	return bpf_tracing_btf_ctx_access(off, size, type, prog, info);
 }
 
-#define DEFINE_STUB_OPS(name)						\
+#define DEFINE_STUB_VERIFIER_OPS(name)					\
 const struct bpf_verifier_ops name##_verifier_ops = {			\
 	.get_func_proto  = stub_tracing_func_proto,			\
 	.is_valid_access = stub_tracing_is_valid_access,		\
-};									\
+};
+
+#define DEFINE_STUB_OPS(name)						\
+DEFINE_STUB_VERIFIER_OPS(name)						\
 const struct bpf_prog_ops name##_prog_ops = {}
 
-DEFINE_STUB_OPS(tracing);
 DEFINE_STUB_OPS(kprobe);
 DEFINE_STUB_OPS(tracepoint);
 DEFINE_STUB_OPS(perf_event);
-DEFINE_STUB_OPS(raw_tracepoint);
+DEFINE_STUB_VERIFIER_OPS(tracing);
+const struct bpf_prog_ops tracing_prog_ops = {
+	.test_run = bpf_prog_test_run_tracing,
+};
+
+DEFINE_STUB_VERIFIER_OPS(raw_tracepoint);
+const struct bpf_prog_ops raw_tracepoint_prog_ops = {
+#ifdef CONFIG_NET
+	.test_run = bpf_prog_test_run_raw_tp,
+#endif
+};
+
 DEFINE_STUB_OPS(raw_tracepoint_writable);
 
 /* --- Tracing kfunc stubs --- */
-- 
