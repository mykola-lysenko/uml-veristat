From 8b7f9ef5f2e8df4b2c71f4df8d3eaa7e542d5b84 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 8 May 2026 12:00:00 -0700
Subject: [PATCH] selftests/bpf: avoid trace_printk in arena spin lock fallback

arena_spin_lock.bpf.o is a TC program, and TC helper availability only
exposes bpf_trace_printk() when the token is CAP_PERFMON-capable. That is
not true for the normal unprivileged uml-veristat run.

The two bpf_printk() calls are debug-only fallbacks after
cond_break_label() guards that exist to prove loop termination to the
verifier. Returning the current value is enough for the impossible fallback
path and avoids making the object depend on a capability-gated helper.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 tools/testing/selftests/bpf/progs/bpf_arena_spin_lock.h | 2 --
 1 file changed, 2 deletions(-)

diff --git a/tools/testing/selftests/bpf/progs/bpf_arena_spin_lock.h b/tools/testing/selftests/bpf/progs/bpf_arena_spin_lock.h
index f90531cf3..65755c04d 100644
--- a/tools/testing/selftests/bpf/progs/bpf_arena_spin_lock.h
+++ b/tools/testing/selftests/bpf/progs/bpf_arena_spin_lock.h
@@ -165,7 +165,6 @@ static __always_inline u32 xchg_tail(arena_spinlock_t __arena *lock, u32 tail)
 
 	return old;
 out:
-	bpf_printk("RUNTIME ERROR: %s unexpected cond_break exit!!!", __func__);
 	return old;
 }
 
@@ -221,7 +220,6 @@ u32 arena_fetch_set_pending_acquire(arena_spinlock_t __arena *lock)
 
 	return old;
 out:
-	bpf_printk("RUNTIME ERROR: %s unexpected cond_break exit!!!", __func__);
 	return old;
 }
 
