From 5e18e8239ca6615bdd876f871b7292edc90e0c9a Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Wed, 22 Apr 2026 15:04:38 -0700
Subject: [PATCH] selftests/bpf: veristat: fix up zero key_size and value_size
 in maps

Benchmark programs like bloom_filter_bench, bpf_hashmap_lookup, and
htab_mem_bench define maps with zero key_size and/or value_size,
expecting the benchmark harness to fill these in at runtime via
bpf_map__set_key_size() / bpf_map__set_value_size().

When veristat processes these files, fixup_obj_maps() already handles
max_entries == 0 by setting it to 1, but does not fix up zero key_size
or value_size.  This causes bpf_object__prepare() to fail with EINVAL
(-22) from the kernel's map_create path.

Add fixups for value_size and key_size for ordinary array, hash, and
bloom-filter maps after applying the existing max_entries fixup. Bloom
filters keep key_size == 0 by design, so only max_entries and value_size
are fixed up for them.

Also add BPF_MAP_TYPE_PERCPU_CGROUP_STORAGE to the exclusion list
alongside CGROUP_STORAGE, since percpu cgroup storage requires
max_entries == 0 and would fail if set to 1.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 tools/testing/selftests/bpf/veristat.c | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/tools/testing/selftests/bpf/veristat.c b/tools/testing/selftests/bpf/veristat.c
index 5c82950e6..f27640220 100644
--- a/tools/testing/selftests/bpf/veristat.c
+++ b/tools/testing/selftests/bpf/veristat.c
@@ -1253,9 +1253,27 @@ static void fixup_obj_maps(struct bpf_object *obj)
 		case BPF_MAP_TYPE_CGRP_STORAGE:
+		case BPF_MAP_TYPE_PERCPU_CGROUP_STORAGE:
 		case BPF_MAP_TYPE_STRUCT_OPS:
 			break;
 		default:
 			if (bpf_map__max_entries(map) == 0)
 				bpf_map__set_max_entries(map, 1);
+			switch (bpf_map__type(map)) {
+			case BPF_MAP_TYPE_ARRAY:
+			case BPF_MAP_TYPE_PERCPU_ARRAY:
+			case BPF_MAP_TYPE_HASH:
+			case BPF_MAP_TYPE_PERCPU_HASH:
+			case BPF_MAP_TYPE_LRU_HASH:
+			case BPF_MAP_TYPE_LRU_PERCPU_HASH:
+			case BPF_MAP_TYPE_BLOOM_FILTER:
+				break;
+			default:
+				continue;
+			}
+			if (bpf_map__value_size(map) == 0)
+				bpf_map__set_value_size(map, 1);
+			if (bpf_map__key_size(map) == 0 &&
+			    bpf_map__type(map) != BPF_MAP_TYPE_BLOOM_FILTER)
+				bpf_map__set_key_size(map, 4);
 		}
 	}
 }
