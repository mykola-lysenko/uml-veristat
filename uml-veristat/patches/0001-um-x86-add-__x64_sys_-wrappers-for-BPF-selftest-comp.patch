From 845aae3020e0c15cff388dfee7548679f4e2329b Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Mon, 20 Apr 2026 18:52:41 -0400
Subject: [PATCH] um/x86: add __x64_sys_* wrappers for BPF selftest
 compatibility

BPF selftests compiled for x86-64 use the '__x64_' SYS_PREFIX when
attaching fentry/kprobe/raw_tp programs (see bpf_misc.h). On native
x86-64 kernels, ARCH_HAS_SYSCALL_WRAPPER generates a real
asmlinkage long __x64_sys_<name>(const struct pt_regs *regs)
function for every syscall. These functions appear in the kernel BTF
as BTF_KIND_FUNC entries, which libbpf resolves at BPF object open time.

UML does not use syscall wrappers, so these BTF entries are absent and
libbpf fails with -ESRCH when trying to resolve the attach target.

Add minimal __x64_sys_* wrapper functions for the five syscalls that
BPF selftests reference via SYS_PREFIX: getpgid, nanosleep, prctl,
prlimit64, and setdomainname. Each wrapper has the canonical x86-64
syscall wrapper signature so pahole emits the correct BTF_KIND_FUNC
entry. Arguments are extracted using UPT_SYSCALL_ARGn() macros.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/x86/um/Makefile               |  2 +-
 arch/x86/um/x64_syscall_wrappers.c | 71 ++++++++++++++++++++++++++++++
 2 files changed, 72 insertions(+), 1 deletion(-)
 create mode 100644 arch/x86/um/x64_syscall_wrappers.c

diff --git a/arch/x86/um/Makefile b/arch/x86/um/Makefile
index f9ea75bf4..8bfac9ce8 100644
--- a/arch/x86/um/Makefile
+++ b/arch/x86/um/Makefile
@@ -26,7 +26,7 @@ subarch-y += ../kernel/sys_ia32.o
 
 else
 
-obj-y += mem_64.o syscalls_64.o vdso/
+obj-y += mem_64.o syscalls_64.o x64_syscall_wrappers.o vdso/
 
 subarch-y = ../lib/csum-partial_64.o ../lib/memcpy_64.o \
 	../lib/memmove_64.o ../lib/memset_64.o
diff --git a/arch/x86/um/x64_syscall_wrappers.c b/arch/x86/um/x64_syscall_wrappers.c
new file mode 100644
index 000000000..294ebeeef
--- /dev/null
+++ b/arch/x86/um/x64_syscall_wrappers.c
@@ -0,0 +1,71 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * UML x86-64: __x64_sys_* wrappers for BPF selftest compatibility
+ *
+ * BPF selftests compiled for x86-64 use the "__x64_" SYS_PREFIX when
+ * attaching fentry/kprobe/raw_tp programs (see bpf_misc.h).  On native
+ * x86-64 kernels, ARCH_HAS_SYSCALL_WRAPPER generates a real
+ *   asmlinkage long __x64_sys_<name>(const struct pt_regs *regs)
+ * function for every syscall.  These functions appear in the kernel BTF
+ * as BTF_KIND_FUNC entries, which libbpf resolves at BPF object open time.
+ *
+ * UML does not use syscall wrappers, so these BTF entries are absent and
+ * libbpf fails with -ESRCH.
+ *
+ * This file provides minimal __x64_sys_* wrapper functions for the five
+ * syscalls that BPF selftests reference via SYS_PREFIX.  Each wrapper has
+ * the canonical x86-64 syscall wrapper signature so that pahole emits the
+ * correct BTF_KIND_FUNC entry.  The bodies extract arguments using the
+ * UPT_SYSCALL_ARGn() macros (di=arg1, si=arg2, dx=arg3, r10=arg4,
+ * r8=arg5, r9=arg6) and delegate to the underlying sys_* function.
+ */
+
+#include <linux/kernel.h>
+#include <linux/syscalls.h>
+#include <linux/time.h>
+#include <linux/resource.h>
+#include <asm/ptrace.h>
+#include <sysdep/ptrace.h>
+
+asmlinkage long __x64_sys_getpgid(const struct pt_regs *regs);
+asmlinkage long __x64_sys_nanosleep(const struct pt_regs *regs);
+asmlinkage long __x64_sys_prctl(const struct pt_regs *regs);
+asmlinkage long __x64_sys_prlimit64(const struct pt_regs *regs);
+asmlinkage long __x64_sys_setdomainname(const struct pt_regs *regs);
+
+asmlinkage long __x64_sys_getpgid(const struct pt_regs *regs)
+{
+	return sys_getpgid((pid_t)UPT_SYSCALL_ARG1(&regs->regs));
+}
+
+asmlinkage long __x64_sys_nanosleep(const struct pt_regs *regs)
+{
+	return sys_nanosleep((struct __kernel_timespec __user *)
+			     UPT_SYSCALL_ARG1(&regs->regs),
+			     (struct __kernel_timespec __user *)
+			     UPT_SYSCALL_ARG2(&regs->regs));
+}
+
+asmlinkage long __x64_sys_prctl(const struct pt_regs *regs)
+{
+	return sys_prctl((int)UPT_SYSCALL_ARG1(&regs->regs),
+			 UPT_SYSCALL_ARG2(&regs->regs),
+			 UPT_SYSCALL_ARG3(&regs->regs),
+			 UPT_SYSCALL_ARG4(&regs->regs),
+			 UPT_SYSCALL_ARG5(&regs->regs));
+}
+
+asmlinkage long __x64_sys_prlimit64(const struct pt_regs *regs)
+{
+	return sys_prlimit64((pid_t)UPT_SYSCALL_ARG1(&regs->regs),
+			     (unsigned int)UPT_SYSCALL_ARG2(&regs->regs),
+			     (const struct rlimit64 __user *)
+			     UPT_SYSCALL_ARG3(&regs->regs),
+			     (struct rlimit64 __user *)UPT_SYSCALL_ARG4(&regs->regs));
+}
+
+asmlinkage long __x64_sys_setdomainname(const struct pt_regs *regs)
+{
+	return sys_setdomainname((char __user *)UPT_SYSCALL_ARG1(&regs->regs),
+				 (int)UPT_SYSCALL_ARG2(&regs->regs));
+}
-- 
2.34.1
