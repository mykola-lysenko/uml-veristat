From 4e6b2f6d4a7ac25b8227c00db4a8bdff2440c41b Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Sat, 9 May 2026 12:00:00 -0700
Subject: [PATCH] libbpf: tolerate duplicate target type IDs in CO-RE relocation

Some kernel BTFs can contain multiple compatible named composite types.
For field and existence CO-RE relocations, every matching candidate must
lead to the same relocation decision because the generated instruction
depends on the candidate layout.

BPF_CORE_TYPE_ID_TARGET is different. The relocation result is only the
target BTF type ID. If two otherwise compatible candidates differ only by
their BTF IDs, either ID is a valid target type for helpers such as
bpf_rdonly_cast(). Treat later compatible target-type candidates as
duplicates and keep the first match instead of rejecting the object with a
relocation ambiguity.

This mirrors duplicate compatible base-candidate handling in
btf_relocate.c.

Add a core_reloc selftest with duplicate compatible target BTF types to
cover the safe TYPE_ID_TARGET ambiguity case.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 tools/lib/bpf/relo_core.c                     | 12 ++++++++++++
 .../selftests/bpf/prog_tests/core_reloc.c     |  1 +
 ...tf__core_reloc_type_id___dup_compat_types.c |  4 ++++
 .../selftests/bpf/progs/core_reloc_types.h    | 14 ++++++++++++++
 4 files changed, 31 insertions(+)

diff --git a/tools/lib/bpf/relo_core.c b/tools/lib/bpf/relo_core.c
index 6ae3f2a15..9de6cfec0 100644
--- a/tools/lib/bpf/relo_core.c
+++ b/tools/lib/bpf/relo_core.c
@@ -1385,6 +1385,18 @@ int bpf_core_calc_relo_insn(const char *prog_name,
 			return -EINVAL;
 		} else if (cand_res.poison != targ_res->poison ||
 			   cand_res.new_val != targ_res->new_val) {
+			/* TYPE_ID_TARGET: duplicate types with different BTF IDs
+			 * are safe to resolve to the first (canonical) match.
+			 * See btf_relocate.c for the same approach.
+			 */
+			if (relo->kind == BPF_CORE_TYPE_ID_TARGET &&
+			    !cand_res.poison && !targ_res->poison) {
+				pr_debug("prog '%s': relo #%d: TYPE_ID_TARGET ambiguity: keeping first candidate (id %llu), skipping duplicate (id %llu)\n",
+					 prog_name, relo_idx,
+					 (unsigned long long)targ_res->new_val,
+					 (unsigned long long)cand_res.new_val);
+				continue;
+			}
 			/* all candidates should result in the same relocation
 			 * decision and value, otherwise it's dangerous to
 			 * proceed due to ambiguity
diff --git a/tools/testing/selftests/bpf/prog_tests/core_reloc.c b/tools/testing/selftests/bpf/prog_tests/core_reloc.c
index 08963c82f..aedb649ef 100644
--- a/tools/testing/selftests/bpf/prog_tests/core_reloc.c
+++ b/tools/testing/selftests/bpf/prog_tests/core_reloc.c
@@ -889,6 +889,7 @@ static const struct core_reloc_test_case test_cases[] = {
 
 	/* BTF_TYPE_ID_LOCAL/BTF_TYPE_ID_TARGET tests */
 	TYPE_ID_CASE(type_id, setup_type_id_case_success),
+	TYPE_ID_CASE(type_id___dup_compat_types, setup_type_id_case_success),
 	TYPE_ID_CASE(type_id___missing_targets, setup_type_id_case_failure),
 
 	/* Enumerator value existence and value relocations */
diff --git a/tools/testing/selftests/bpf/progs/btf__core_reloc_type_id___dup_compat_types.c b/tools/testing/selftests/bpf/progs/btf__core_reloc_type_id___dup_compat_types.c
new file mode 100644
index 000000000..a7b4c2951
--- /dev/null
+++ b/tools/testing/selftests/bpf/progs/btf__core_reloc_type_id___dup_compat_types.c
@@ -0,0 +1,4 @@
+// SPDX-License-Identifier: GPL-2.0
+#include "core_reloc_types.h"
+
+void f(struct core_reloc_type_id___dup_compat_types x) {}
diff --git a/tools/testing/selftests/bpf/progs/core_reloc_types.h b/tools/testing/selftests/bpf/progs/core_reloc_types.h
index 5760ae015..081a3f195 100644
--- a/tools/testing/selftests/bpf/progs/core_reloc_types.h
+++ b/tools/testing/selftests/bpf/progs/core_reloc_types.h
@@ -1196,6 +1196,20 @@ struct core_reloc_type_id {
 	arr_typedef f6;
 };
 
+struct a_struct___dup_compat {
+	int x;
+};
+
+struct core_reloc_type_id___dup_compat_types {
+	struct a_struct f1;
+	struct a_struct___dup_compat f2;
+	union a_union f3;
+	enum an_enum f4;
+	named_struct_typedef f5;
+	func_proto_typedef f6;
+	arr_typedef f7;
+};
+
 struct core_reloc_type_id___missing_targets {
 	/* nothing */
 };
